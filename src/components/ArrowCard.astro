---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "@components/FormattedDate.astro";

type Props = {
  entry: CollectionEntry<"blog"> | CollectionEntry<"projects">;
}

const { entry } = Astro.props;
const isBlog = entry.collection === "blog";
const tags = isBlog ? (entry as CollectionEntry<"blog">).data.tags : undefined;
---

<a href={`/${entry.collection}/${entry.slug}`} class="group flex py-3 px-4 rounded-lg border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out">
  <div class="flex items-start justify-between gap-3 w-full">
    <div class="flex flex-col flex-1 min-w-0">
      {isBlog && (
        <div class="text-xs text-black/40 dark:text-white/40 mb-1">
          <FormattedDate date={entry.data.date} />
        </div>
      )}
      <div class="font-semibold">
        {entry.data.title}
      </div>
      <div class="text-sm mt-1">
        {entry.data.description}
      </div>
      {tags && tags.length > 0 && (
        <div class="text-xs text-black/40 dark:text-white/40 mt-2 space-x-2">
          {tags.map(tag => <span>#{tag}</span>)}
        </div>
      )}
    </div>
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      viewBox="0 0 24 24"
      class="shrink-0 mt-0.5 size-5 stroke-2 fill-none stroke-current">
      <line x1="5" y1="12" x2="19" y2="12" class="translate-x-3 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out" />
      <polyline points="12 5 19 12 12 19" class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out" />
    </svg>
  </div>
</a>
